  timestamp: now()
}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus"><![CDATA[501]]></ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
		<on-error-propagate enableNotifications="true" logException="true" doc:name="On Error Propagate" doc:id="7755d83c-224d-4596-9ed7-1a87f305b981" type="DB:CONNECTIVITY">
			<set-variable value="500" doc:name="Set Variable" doc:id="f6e0bd81-db60-4b35-8b07-594a51bdd82f" variableName="httpStatus"/>
			<ee:transform doc:name="Transform Message" doc:id="d256c7fa-2053-406a-8556-d9aac53907dd" >
				<ee:message >
					<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
{
  errorCode: vars.httpStatus,
  message: error.description default "DB Connectivity error",
  correlationId: correlationId,
  timestamp: now()
}]]></ee:set-payload>
				</ee:message>
			</ee:transform>
		</on-error-propagate>
		<on-error-propagate enableNotifications="true" logException="true" doc:name="On Error Propagate" doc:id="49d284b5-a363-41cd-bc61-780f789f341e" type="DB:QUERY_EXECUTION">
			<set-variable value="500" doc:name="Set Variable" doc:id="4a038116-b0cf-4158-8687-d9dc6d64faf8" variableName="httpStatus" />
			<ee:transform doc:name="Transform Message" doc:id="52e56f49-1c41-488a-af56-f53bcf82a1cb" >
				<ee:message >
					<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
{
  errorCode: vars.httpStatus,
