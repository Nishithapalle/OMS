output application/json
---
{
  errorCode: "405",
  message: error.description default "Method Not Allowed",
  correlationId: correlationId,
  timestamp: now()
	
}]]></ee:set-payload>
                    </ee:message>
                    <ee:variables>
                        <ee:set-variable variableName="httpStatus"><![CDATA[405]]></ee:set-variable>
                    </ee:variables>
                </ee:transform>
            </on-error-propagate>
